# syntax=docker/dockerfile:1
ARG SOURCE_IMAGE=vllm-node
ARG BASE_IMAGE=nvcr.io/nvidia/pytorch:26.01-py3

# === Stage 1: Split dist-packages ===
FROM ${SOURCE_IMAGE} AS splitter
COPY stages/directory_split2.sh /tmp/directory_split2.sh
RUN bash /tmp/directory_split2.sh \
      /usr/local/lib/python3.12/dist-packages 4 \
      --exclude "transformers*"

# === Stage 2: Re-layer onto clean base ===
FROM ${BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_BREAK_SYSTEM_PACKAGES=1 \
    VLLM_BASE_DIR=/workspace/vllm \
    PIP_CACHE_DIR=/root/.cache/pip \
    UV_CACHE_DIR=/root/.cache/uv \
    UV_SYSTEM_PYTHON=1 \
    UV_BREAK_SYSTEM_PACKAGES=1 \
    UV_LINK_MODE=copy

# Replicate runner's APT + uv setup (matches upstream Dockerfile runner stage)
RUN apt update && \
    apt install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-dev \
    vim \
    curl \
    git \
    wget \
    libcudnn9-cuda-13 \
    libnccl-dev \
    libnccl2 \
    libibverbs1 \
    libibverbs-dev \
    rdma-core \
    libxcb1 \
    && rm -rf /var/lib/apt/lists/* && \
    pip install uv && (pip uninstall -y flash-attn || true)

WORKDIR /workspace/vllm

# Copy split dist-packages as separate layers (each <10GB)
COPY --from=splitter /usr/local/lib/python3.12/dist-packages-1/ /usr/local/lib/python3.12/dist-packages/
COPY --from=splitter /usr/local/lib/python3.12/dist-packages-2/ /usr/local/lib/python3.12/dist-packages/
COPY --from=splitter /usr/local/lib/python3.12/dist-packages-3/ /usr/local/lib/python3.12/dist-packages/
COPY --from=splitter /usr/local/lib/python3.12/dist-packages-4/ /usr/local/lib/python3.12/dist-packages/

# Transformers in its own layer (better sharing between tf4/tf5 variants)
COPY --from=splitter --parents /usr/local/lib/python3.12/dist-packages/transformers* /

# Binaries (vllm CLI, ray, uv, etc.)
COPY --from=splitter /usr/local/bin/ /usr/local/bin/

# Workspace files (tiktoken encodings, etc.)
COPY --from=splitter /workspace/ /workspace/

# sparkrun build provenance labels (injected by CI from build-metadata.yaml)
ARG SPARKRUN_REPO_COMMIT=""
ARG SPARKRUN_VLLM_HASH=""
ARG SPARKRUN_FLASHINFER_HASH=""
ARG SPARKRUN_BUILD_FLAGS=""
LABEL dev.sparkrun.repo-commit="${SPARKRUN_REPO_COMMIT}" \
      dev.sparkrun.vllm-hash="${SPARKRUN_VLLM_HASH}" \
      dev.sparkrun.flashinfer-hash="${SPARKRUN_FLASHINFER_HASH}" \
      dev.sparkrun.build-flags="${SPARKRUN_BUILD_FLAGS}"

# Runtime environment (matches upstream Dockerfile lines 264-271)
ARG TORCH_CUDA_ARCH_LIST="12.1a"
ENV TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH_LIST} \
    FLASHINFER_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH_LIST} \
    TRITON_PTXAS_PATH=/usr/local/cuda/bin/ptxas \
    TIKTOKEN_ENCODINGS_BASE=/workspace/vllm/tiktoken_encodings \
    PATH=/workspace/vllm:$PATH
